NODE_ENV=development
# Production deployments enforce the security evidence profile. Use gdpr, hipaa, or gdpr_hipaa when applicable.
COMPLIANCE_PROFILE=gdpr_hipaa
SECURITY_PROGRAM_OWNER=
RISK_ASSESSMENT_REVIEWED_AT=
INCIDENT_RESPONSE_PLAN_VERSION=
DATA_RETENTION_POLICY_VERSION=
BACKUP_RESTORE_TESTED_AT=
ACCESS_REVIEW_COMPLETED_AT=
SUBPROCESSOR_REGISTER_VERSION=
PRIVACY_PROGRAM_OWNER=
PRIVACY_NOTICE_VERSION=
DATA_PROCESSING_AGREEMENT_VERSION=
RECORDS_OF_PROCESSING_VERSION=
DATA_SUBJECT_RIGHTS_PROCEDURE_VERSION=
INTERNATIONAL_TRANSFER_MECHANISM=
HIPAA_SECURITY_OFFICIAL=
HIPAA_RISK_ANALYSIS_REVIEWED_AT=
HIPAA_BAA_TEMPLATE_VERSION=
HIPAA_SUBCONTRACTOR_BAA_REGISTER_VERSION=
HIPAA_BREACH_PROCEDURE_VERSION=
HIPAA_WORKFORCE_TRAINING_COMPLETED_AT=
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=false
RATE_LIMIT_AUTH_REQUESTS=30
RATE_LIMIT_AI_REQUESTS=30
RATE_LIMIT_FILE_REQUESTS=20
RATE_LIMIT_WRITE_REQUESTS=120
RATE_LIMIT_WEBHOOK_REQUESTS=300
MIGRATION_MAX_BODY_BYTES=20000000
DOCUMENT_MAX_BYTES=25000000
DOCUMENT_STORAGE_PROVIDER=postgres
DOCUMENT_STORAGE_PATH=./data/documents
FILE_MALWARE_SCANNER=basic
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000
PUBLIC_BASE_URL=https://replace-with-your-atlas-hostname
DATABASE_URL=postgresql://atlas:atlas@127.0.0.1:5432/atlas
# Local demo only. Leave unset in production, which must use PostgreSQL.
# LOCAL_DATA_PATH=.atlas-data/repository.bin
AUTH_TOKEN_SECRET=replace-with-at-least-32-random-characters
MFA_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=512
DOCUMENT_INDEX_BATCH_SIZE=50
DOCUMENT_INDEX_INTERVAL_MS=60000
AI_WEB_SEARCH_ENABLED=true
AI_WEB_SEARCH_CONTEXT_SIZE=medium
OPENAI_API_KEY=replace-with-secret-from-platform.openai.com
AI_CONTENT_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32
AI_CONTENT_ENCRYPTION_KEY_ID=primary
CMS_CREDENTIAL_ENCRYPTION_KEY=replace-with-separate-output-of-openssl-rand-base64-32
CMS_CREDENTIAL_ENCRYPTION_KEY_ID=cms-primary
CMS_SYNC_ENABLED=true
INTELLIGENCE_WORKER_ENABLED=true
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
MICROSOFT_365_CLIENT_ID=
MICROSOFT_365_CLIENT_SECRET=
MICROSOFT_365_TENANT=organizations
# JSON array mapping each public website to one firm, attorney, and ingestion token.
ATLAS_PUBLIC_WEBSITE_CONNECTIONS=[]
# Active attorney-approved fixed-scope divorce services. Each entry must include
# serviceId, templateId, version, label, scopeSummary, excludedSummary,
# agreementText, allowedMergeFields ["clientName","agreementDate"],
# approvalStatus "active_attorney_approved", and approved priceMinor/currency.
ATLAS_DIVORCE_DIGITAL_SERVICE_CATALOG=[]
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
WESTLAW_CLIENT_ID=
WESTLAW_CLIENT_SECRET=
WESTLAW_TOKEN_ENDPOINT=
WESTLAW_SEARCH_ENDPOINT=
WESTLAW_SCOPE=
LEXISNEXIS_CLIENT_ID=
LEXISNEXIS_CLIENT_SECRET=
LEXISNEXIS_TOKEN_ENDPOINT=
LEXISNEXIS_SEARCH_ENDPOINT=
LEXISNEXIS_SCOPE=

# Docusign eSignature system sender. Requires one-time Docusign impersonation consent.
DOCUSIGN_WORKSPACE_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY_BASE64=
DOCUSIGN_AUTH_BASE_URL=https://account-d.docusign.com
DOCUSIGN_API_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_RETURN_URL=https://atlas.example/#documents
DOCUSIGN_CONNECT_HMAC_KEY=

# Aggregate-only, official public marketing feeds. Never configure person-level or case-level records.
# Expected response: [{"date":"2026-07-01","jurisdiction":"Example County, DE","count":12,"sourceUrl":"https://official.example/data"}]
MARKETING_PUBLIC_DATA_SOURCES=[]
CRYPTO_PROVIDER_NAME=base-usdc
CRYPTO_EVM_RPC_URL=
CRYPTO_NETWORK=base
CRYPTO_CHAIN_ID=8453
CRYPTO_ASSET=USDC
CRYPTO_TOKEN_ADDRESS=
CRYPTO_DECIMALS=6
CRYPTO_CONFIRMATIONS=12
CRYPTO_PLATFORM_WALLET_ADDRESS=
CRYPTO_SUBSCRIPTION_PLAN=professional
CRYPTO_SUBSCRIPTION_PRICE_MINOR=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_CHECKOUT_SIGNING_SECRET=replace-with-at-least-32-random-characters
PAYMENT_RETURN_URL=https://replace-with-your-atlas-hostname/
TWILIO_AUTH_TOKEN=
VOICE_PUBLIC_BASE_URL=https://replace-with-your-public-atlas-hostname
TWILIO_ACCOUNT_SID=
TWILIO_MESSAGING_FROM=
INGESTION_WEBHOOK_SECRETS={"wsp_example:phone":"replace-with-at-least-32-random-characters"}
